# Pharmagen - Environment Variables
# Copy to .env and fill in values

# API base URL (frontend)
VITE_API_URL=http://127.0.0.1:8000

# --- Backend (API) ---

# Optional: require X-API-Key header when set
# API_KEY=your-secret-key

# Rate limiting (default: 100 req/60s per IP)
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SEC=60

# CORS origins (comma-separated, or omit for *)
# CORS_ORIGINS=https://yourapp.com,https://demo.yourapp.com

# AI features (optional)
# OPENAI_API_KEY=sk-...
